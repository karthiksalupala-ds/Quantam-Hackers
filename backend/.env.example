# ─── LLM API Keys ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
HUGGINGFACE_API_TOKEN=your_hf_token_here

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── App Settings ──────────────────────────────────────────────
# Primary LLM provider: groq | openai | openrouter | gemini
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Embedding provider: huggingface | openai
EMBEDDING_PROVIDER=huggingface

# Enable demo mode (no real API calls) when keys are absent
DEMO_MODE=false

# ─── Research APIs (all free, no key needed) ──────────────────
SEMANTIC_SCHOLAR_API_KEY=
# (Optional) NCBI API key for higher PubMed rate limits
NCBI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
